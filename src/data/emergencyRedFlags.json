  "rules": [
    {
      "id": "infant_fever_under_3_months",
      "label": "Температура/лихорадка у младенца до 3 месяцев",
      "severity": "emergency",
      "type": "age_condition",
      "trigger": {
        "anyKeywords": [
          "температура",
          "лихорадка",
          "жар",
          "высокая температура"
        ],
        "symptomIdsAny": [
          "temperature",
          "fever"
        ],
        "age": {
          "maxYearsExclusive": 1
        }
      },
      "userFacingMessage": "Температура или лихорадка у младенца требует срочной очной оценки врача.",
      "recommendedAction": "seek_urgent_care",
      "blockMedicationSuggestions": true
    },
    {
