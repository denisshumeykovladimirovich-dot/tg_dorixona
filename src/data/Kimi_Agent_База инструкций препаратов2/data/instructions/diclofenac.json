    "sideEffects": {
      "structured": [
        {
          "content": "Со стороны ЖКТ: тошнота, рвота, диспепсия, боли в животе, диарея, кровотечения",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "diclofenac-sideEffects-ru-0"
        },
        {
          "content": "Со стороны ЦНС: головная боль, головокружение, сонливость",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "diclofenac-sideEffects-ru-1"
        },
        {
          "content": "Аллергические реакции: кожная сыпь, крапивница, отек Квинке, анафилактический шок",
