    "sideEffects": {
      "structured": [
        {
          "content": "Аллергические реакции: кожная сыпь, крапивница, отек Квинке, анафилактический шок",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "amoxicillin-sideEffects-ru-0"
        },
        {
          "content": "Со стороны ЖКТ: тошнота, рвота, диарея, дисбактериоз",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "amoxicillin-sideEffects-ru-1"
        },
        {
          "content": "Со стороны печени: повышение печеночных ферментов, холестатический гепатит",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "amoxicillin-sideEffects-ru-2"
        },
        {
          "content": "Со стороны нервной системы: головная боль, головокружение",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "amoxicillin-sideEffects-ru-3"
        },
        {
          "content": "Суперинфекция",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "amoxicillin-sideEffects-ru-4"
        }
      ],
