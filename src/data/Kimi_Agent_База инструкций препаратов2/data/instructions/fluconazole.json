    "sideEffects": {
      "structured": [
        {
          "content": "Со стороны ЖКТ: тошнота, рвота, диарея, боли в животе, диспепсия",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "fluconazole-sideEffects-ru-0"
        },
        {
          "content": "Со стороны печени: повышение печеночных ферментов, гепатит, печеночная недостаточность",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "fluconazole-sideEffects-ru-1"
        },
        {
          "content": "Аллергические реакции: кожная сыпь, крапивница, синдром Стивенса-Джонсона",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "fluconazole-sideEffects-ru-2"
        },
        {
          "content": "Головная боль, головокружение",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "fluconazole-sideEffects-ru-3"
        },
        {
          "content": "Удлинение интервала QT",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "fluconazole-sideEffects-ru-4"
        }
      ],
