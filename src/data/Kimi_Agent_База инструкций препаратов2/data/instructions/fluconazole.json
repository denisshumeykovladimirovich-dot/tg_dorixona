    "dosageAndAdministration": {
      "structured": {
        "general": [],
        "adults": [
          {
            "content": "При кандидозе полости рта и пищевода: по 50-100 мг 1 раз в сутки в течение 7-14 дней",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "fluconazole-dosage-adults-ru-0"
          },
          {
            "content": "При генитальном кандидозе: 150 мг однократно",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "fluconazole-dosage-adults-ru-1"
          },
          {
            "content": "При криптококковом менингите: 400 мг в первый день, затем по 200-400 мг 1 раз в сутки в течение 6-8 недель",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "fluconazole-dosage-adults-ru-2"
          },
          {
            "content": "Капсулы принимать внутрь, независимо от приема пищи",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "fluconazole-dosage-adults-ru-3"
          }
        ],
        "children": [
          {
            "content": "Детям: доза рассчитывается из расчета 3-6 мг/кг/сут",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "fluconazole-dosage-children-ru-0"
          },
          {
            "content": "Детям до 6 месяцев: применение противопоказано",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "fluconazole-dosage-children-ru-1"
          }
        ],
        "ageSpecific": [],
        "routeSpecific": []
      },
