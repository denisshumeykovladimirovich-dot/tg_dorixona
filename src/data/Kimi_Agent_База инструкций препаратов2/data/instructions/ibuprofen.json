    "dosageAndAdministration": {
      "structured": {
        "general": [],
        "adults": [
          {
            "content": "Взрослым и детям старше 12 лет (масса тела более 40 кг): по 200-400 мг 3-4 раза в сутки",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ibuprofen-dosage-adults-ru-0"
          },
          {
            "content": "Максимальная суточная доза - 1200 мг (без назначения врача)",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ibuprofen-dosage-adults-ru-1"
          },
          {
            "content": "При необходимости кратковременное увеличение дозы до 2400 мг/сут по назначению врача",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ibuprofen-dosage-adults-ru-2"
          },
          {
            "content": "Препарат следует принимать после еды, запивая водой",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ibuprofen-dosage-adults-ru-3"
          }
        ],
        "children": [
          {
            "content": "Дети 6-12 лет (20-40 кг): по 200 мг до 4 раз в сутки (максимум 800 мг/сут)",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ibuprofen-dosage-children-ru-0"
          },
          {
            "content": "Дети с массой тела менее 20 кг: препарат не применяется",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ibuprofen-dosage-children-ru-1"
          },
          {
            "content": "Интервал между приемами - не менее 6 часов",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ibuprofen-dosage-children-ru-2"
          }
        ],
