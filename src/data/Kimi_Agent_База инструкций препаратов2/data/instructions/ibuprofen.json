    "contraindications": {
      "structured": [
        {
          "content": "Гиперчувствительность к ибупрофену или другим НПВП",
          "contentType": "contraindication",
          "language": "ru",
          "sourceRef": "ibuprofen-contraindications-ru-0"
        },
        {
          "content": "Анамнез бронхоспазма, крапивницы, ринита после приема ацетилсалициловой кислоты или других НПВП",
          "contentType": "contraindication",
          "language": "ru",
          "sourceRef": "ibuprofen-contraindications-ru-1"
        },
        {
          "content": "Язвенная болезнь желудка и двенадцатиперстной кишки в активной фазе или в анамнезе",
          "contentType": "contraindication",
          "language": "ru",
          "sourceRef": "ibuprofen-contraindications-ru-2"
        },
        {
          "content": "Кровотечение или перфорация ЖКТ в анамнезе",
          "contentType": "contraindication",
          "language": "ru",
          "sourceRef": "ibuprofen-contraindications-ru-3"
        },
        {
          "content": "Тяжелая печеночная, почечная или сердечная недостаточность",
          "contentType": "contraindication",
          "language": "ru",
          "sourceRef": "ibuprofen-contraindications-ru-4"
        },
        {
          "content": "III триместр беременности",
          "contentType": "contraindication",
          "language": "ru",
          "sourceRef": "ibuprofen-contraindications-ru-5"
        },
        {
          "content": "Дети с массой тела ниже 40 кг",
          "contentType": "contraindication",
          "language": "ru",
          "sourceRef": "ibuprofen-contraindications-ru-6"
        }
      ],
