    "sideEffects": {
      "structured": [
        {
          "content": "Со стороны ЖКТ: тошнота, рвота, диспепсия, боли в животе, диарея, запор",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "ibuprofen-sideEffects-ru-0"
        },
        {
          "content": "Со стороны ЦНС: головная боль, головокружение, сонливость, бессонница",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "ibuprofen-sideEffects-ru-1"
        },
        {
          "content": "Аллергические реакции: кожная сыпь, зуд, крапивница, отек Квинке, анафилактический шок",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "ibuprofen-sideEffects-ru-2"
        },
        {
          "content": "Со стороны сердечно-сосудистой системы: повышение АД, отеки, сердцебиение",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "ibuprofen-sideEffects-ru-3"
        },
        {
          "content": "Нарушения функции почек и печени",
          "contentType": "sideEffect",
          "language": "ru",
          "sourceRef": "ibuprofen-sideEffects-ru-4"
        }
      ],
