    "dosageAndAdministration": {
      "structured": {
        "general": [],
        "adults": [
          {
            "content": "Взрослым и детям старше 12 лет: по 30 мг (1 таблетка) 3 раза в сутки в первые 2-3 дня, затем по 30 мг 2 раза в сутки",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ambroxol-dosage-adults-ru-0"
          },
          {
            "content": "Или по 75 мг (1 капсула пролонгированного действия) 1 раз в сутки",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ambroxol-dosage-adults-ru-1"
          },
          {
            "content": "Таблетки принимать после еды, запивая водой",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ambroxol-dosage-adults-ru-2"
          }
        ],
        "children": [
          {
            "content": "Детям 6-12 лет: по 15 мг (1/2 таблетки) 2-3 раза в сутки",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ambroxol-dosage-children-ru-0"
          },
          {
            "content": "Детям 2-6 лет: по 7,5 мг (сироп) 3 раза в сутки",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ambroxol-dosage-children-ru-1"
          },
          {
            "content": "Детям до 2 лет: только по назначению врача (по 7,5 мг 2 раза в сутки)",
            "contentType": "dosage",
            "language": "ru",
            "sourceRef": "ambroxol-dosage-children-ru-2"
          }
        ],
