{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drug-instructions.org/schemas/catalog.schema.json",
  "title": "Drug Catalog Schema",
  "description": "Schema for the drug catalog index file containing metadata and references to instruction files",
  "version": "1.0.0",
  "type": "object",
  "required": ["version", "lastUpdated", "totalCount", "drugs"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for catalog format",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last catalog update"
    },
    "totalCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of drugs in catalog"
    },
    "drugs": {
      "type": "array",
      "description": "Array of drug catalog entries",
      "items": {
        "$ref": "#/$defs/DrugCatalogEntry"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional catalog metadata",
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "lastSync": { "type": "string", "format": "date-time" }
            }
          }
        },
        "statistics": {
          "type": "object",
          "properties": {
            "bySource": { "type": "object" },
            "byLanguage": { "type": "object" },
            "byReviewStatus": { "type": "object" }
          }
        }
      }
    }
  },
  "$defs": {
    "DrugCatalogEntry": {
      "type": "object",
      "required": ["id", "canonicalName", "normalizedKey", "hasOfficialInstruction"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique drug identifier (UUID v4)",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "canonicalName": {
          "type": "object",
          "description": "Canonical drug names in different languages",
          "required": ["ru", "uz"],
          "properties": {
            "ru": {
              "type": "string",
              "description": "Canonical name in Russian",
              "minLength": 1,
              "maxLength": 500
            },
            "uz": {
              "type": "string",
              "description": "Canonical name in Uzbek (Latin script)",
              "minLength": 1,
              "maxLength": 500
            },
            "en": {
              "type": "string",
              "description": "Canonical name in English (international nonproprietary name)",
              "minLength": 1,
              "maxLength": 500
            }
          }
        },
        "normalizedKey": {
          "type": "string",
          "description": "Normalized search key (lowercase, no special chars, for deduplication)",
          "minLength": 1,
          "maxLength": 500,
          "pattern": "^[a-z0-9\\-]+$"
        },
        "aliases": {
          "type": "object",
          "description": "Alternative names and spellings for search",
          "properties": {
            "ru": {
              "type": "array",
              "description": "Russian language aliases",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              },
              "maxItems": 50
            },
            "uz": {
              "type": "array",
              "description": "Uzbek language aliases",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              },
              "maxItems": 50
            },
            "en": {
              "type": "array",
              "description": "English language aliases",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              },
              "maxItems": 50
            },
            "brands": {
              "type": "array",
              "description": "Brand/trade names",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              },
              "maxItems": 100
            },
            "transliterations": {
              "type": "array",
              "description": "Transliterations between Cyrillic and Latin scripts",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              },
              "maxItems": 50
            },
            "commonMisspellings": {
              "type": "array",
              "description": "Common misspellings for fuzzy matching",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              },
              "maxItems": 30
            }
          }
        },
        "searchTokens": {
          "type": "array",
          "description": "Pre-computed search tokens for indexing",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100
          },
          "maxItems": 200
        },
        "therapeuticClass": {
          "type": "array",
          "description": "ATC (Anatomical Therapeutic Chemical) classification codes",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]([0-9]{2}[A-Z]{0,2}[0-9]{0,2})?$",
            "description": "ATC code (e.g., N02BE01 for paracetamol)"
          },
          "maxItems": 10
        },
        "pharmacologicalClass": {
          "type": "array",
          "description": "Pharmacological classification",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "maxItems": 20
        },
        "symptomTags": {
          "type": "array",
          "description": "Associated symptoms and conditions",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "maxItems": 50
        },
        "commonUseCases": {
          "type": "array",
          "description": "Common usage scenarios",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "maxItems": 30
        },
        "dosageForms": {
          "type": "array",
          "description": "Available dosage forms",
          "items": {
            "type": "string",
            "enum": [
              "tablet",
              "capsule",
              "syrup",
              "suspension",
              "injection",
              "infusion",
              "drops",
              "ointment",
              "cream",
              "gel",
              "spray",
              "inhaler",
              "suppository",
              "patch",
              "powder",
              "solution",
              "emulsion",
              "lozenge",
              "other"
            ]
          }
        },
        "ageBucketsSupported": {
          "type": "array",
          "description": "Age groups with approved usage",
          "items": {
            "type": "string",
            "enum": [
              "neonate",
              "infant",
              "toddler",
              "child",
              "adolescent",
              "adult",
              "elderly"
            ]
          }
        },
        "hasOfficialInstruction": {
          "type": "boolean",
          "description": "Whether official instruction file exists"
        },
        "instructionFile": {
          "type": "string",
          "description": "Path to instruction JSON file (relative to data directory)",
          "pattern": "^[a-z0-9\\-]+/[a-z0-9\\-]+\\.json$"
        },
        "sourcePriority": {
          "type": "integer",
          "description": "Priority of source (higher = more authoritative)",
          "minimum": 1,
          "maximum": 10,
          "default": 5
        },
        "reviewStatus": {
          "type": "string",
          "description": "Review status of the entry",
          "enum": [
            "pending",
            "auto_extracted",
            "human_reviewed",
            "medically_verified",
            "deprecated"
          ]
        },
        "needsManualReview": {
          "type": "boolean",
          "description": "Flag for manual review requirement"
        },
        "reviewNotes": {
          "type": "string",
          "description": "Notes from review process",
          "maxLength": 2000
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Entry creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "version": {
          "type": "integer",
          "description": "Entry version number",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  }
}
